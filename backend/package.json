    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  }
