# Copie para `.env` e ajuste ao teu ambiente.

NODE_ENV=development

LOG_LEVEL=info

POSTGRES_DB=usermgmt
POSTGRES_PORT=5432

# Prisma — Postgres sem senha (utilizador local). Com senha depois:
# postgresql://UTILIZADOR:SENHA@localhost:5432/usermgmt
DATABASE_URL=postgresql://postgres@localhost:5432/usermgmt
